@inject SettingsService ConfigService
@inject SkillService SkillService
@inject UpdateService UpdateService
@inject IMemoryService MemoryService
@inject ModelDownloadService ModelDownloads
@using Floaty.Services
@implements IDisposable

<div class="settings" style="@AccentPalette.From(_config.AccentColor).ToCssVariables()">
    <header class="settings-header">
        <h1><i class="ti ti-settings" aria-hidden="true"></i> Settings</h1>
        <p class="subtitle">Configure Floaty behavior and AI provider options.</p>
    </header>

    <section class="settings-panel">
        <aside class="tabs" aria-label="Settings sections">
            <button class="tab @TabClass(SettingsSection.Behavior)"
                    @onclick="() => SelectSection(SettingsSection.Behavior)">
                <i class="ti ti-message-chatbot" aria-hidden="true"></i>
                <span>Behavior</span>
            </button>
            <button class="tab @TabClass(SettingsSection.Appearance)"
                    @onclick="() => SelectSection(SettingsSection.Appearance)">
                <i class="ti ti-palette" aria-hidden="true"></i>
                <span>Appearance</span>
            </button>
            <button class="tab @TabClass(SettingsSection.ModelProvider)"
                    @onclick="() => SelectSection(SettingsSection.ModelProvider)">
                <i class="ti ti-cpu" aria-hidden="true"></i>
                <span>Model Provider</span>
            </button>
            <button class="tab @TabClass(SettingsSection.ScreenHistory)"
                    @onclick="() => SelectSection(SettingsSection.ScreenHistory)">
                <i class="ti ti-history" aria-hidden="true"></i>
                <span>Screen History</span>
            </button>
            <button class="tab @TabClass(SettingsSection.VoiceInput)"
                    @onclick="() => SelectSection(SettingsSection.VoiceInput)">
                <i class="ti ti-microphone" aria-hidden="true"></i>
                <span>Voice Input</span>
            </button>
            <button class="tab @TabClass(SettingsSection.Mcp)"
                    @onclick="() => SelectSection(SettingsSection.Mcp)">
                <i class="ti ti-server-2" aria-hidden="true"></i>
                <span>MCP Servers</span>
            </button>
            <button class="tab @TabClass(SettingsSection.Exec)"
                    @onclick="() => SelectSection(SettingsSection.Exec)">
                <i class="ti ti-terminal-2" aria-hidden="true"></i>
                <span>Shell</span>
            </button>
            <button class="tab @TabClass(SettingsSection.Skills)"
                    @onclick="() => SelectSection(SettingsSection.Skills)">
                <i class="ti ti-bolt" aria-hidden="true"></i>
                <span>Skills</span>
            </button>
            <button class="tab @TabClass(SettingsSection.Updates)"
                    @onclick="() => SelectSection(SettingsSection.Updates)">
                <i class="ti ti-cloud-download" aria-hidden="true"></i>
                <span>Updates</span>
            </button>
        </aside>

        <div class="card">
            @if (_activeSection == SettingsSection.Behavior)
            {
                <div class="card-head">
                    <h2>Behavior</h2>
                    <p>Define Floaty's system prompt used at the start of every chat, and how Floaty starts.</p>
                </div>

                <div class="field">
                    <label for="systemPrompt">System prompt</label>
                    <textarea id="systemPrompt" rows="12" autocomplete="off" spellcheck="false" @bind="_systemPrompt"
                              @bind:event="oninput"></textarea>
                    <span class="hint">Saved locally to <code>~/.floaty/floaty.md</code>.</span>
                </div>

                @if (OperatingSystem.IsWindows())
                {
                    <div class="field">
                        <label for="autostartMode">Start with Windows</label>
                        <select id="autostartMode" @bind="_config.AutostartMode">
                            <option value="@AutostartMode.Disabled">Don't start automatically</option>
                            <option value="@AutostartMode.Minimized">Start minimized (tray only)</option>
                            <option value="@AutostartMode.Visible">Start visible</option>
                        </select>
                        <span class="hint">@AutostartModeHint(_config.AutostartMode)</span>
                    </div>
                }
            }
            else if (_activeSection == SettingsSection.Appearance)
            {
                <div class="card-head">
                    <h2>Appearance</h2>
                    <p>Choose the ring image used by the floating overlay.</p>
                </div>

                <div class="field">
                    <label>Ring image</label>

                    <div class="ring-strip" role="list" aria-label="Ring image options">
                        @foreach (var option in _ringOptions)
                        {
                            <button type="button" role="listitem"
                                    class="ring-option @(IsSelectedRing(option.Value) ? "selected" : string.Empty)"
                                    title="@option.Label" @onclick="() => SelectRing(option.Value)">
                                <span class="ring-preview">
                                    @if (!string.IsNullOrWhiteSpace(option.PreviewSrc))
                                    {
                                        <img src="@option.PreviewSrc" alt="@option.Label" loading="lazy" />
                                    }
                                    else
                                    {
                                        <span class="ring-fallback">@option.Label[..1].ToUpperInvariant()</span>
                                    }
                                </span>
                                <span class="ring-name">@option.Label</span>
                                <span class="ring-kind">@(option.IsBuiltIn ? "Built-in" : "Custom")</span>
                            </button>
                        }
                    </div>

                    <span class="hint">
                        Built-ins come from app resources. Add your own images to <code>~/.floaty/ring</code> and click
                        Reload.
                    </span>
                </div>

                <div class="field">
                    <label for="ringSize">Ring size</label>
                    <div class="ring-size-row">
                        <input id="ringSize" type="range"
                               min="@SettingsService.RingMinSize" max="@SettingsService.RingMaxSize" step="1"
                               value="@((int)_config.RingSize)"
                               @oninput="OnRingSizeInput" />
                        <span class="ring-size-value">@((int)_config.RingSize) px</span>
                    </div>
                    <span class="hint">Drag to resize the overlay ring — it updates live. You can also hold
                        <code>Ctrl</code> and scroll over the ring.</span>
                </div>

                <div class="field">
                    <label>Accent color</label>
                    <div class="accent-row" role="list" aria-label="Accent color options">
                        @foreach (var preset in AccentPresets)
                        {
                            <button type="button" role="listitem"
                                    class="accent-swatch @(IsSelectedAccent(preset.Value) ? "selected" : string.Empty)"
                                    style="background:@preset.Value" title="@preset.Label"
                                    @onclick="() => SelectAccent(preset.Value)"></button>
                        }
                        <input type="color" class="accent-custom" value="@_config.AccentColor"
                               @oninput="OnAccentColorInput" title="Custom color" />
                    </div>
                    <span class="hint">Used for buttons, chat bubbles and highlights. Previews live; committed on
                        Save.</span>
                </div>

                <div class="actions sub-actions">
                    <button class="reload" @onclick="ReloadRingImages">
                        <i class="ti ti-refresh" aria-hidden="true"></i>
                        <span>Reload</span>
                    </button>
                    <span class="hint">Loaded @_ringOptions.Count option(s), including @_customRingCount custom
                        image(s).</span>
                    </div>
                }
            else if (_activeSection == SettingsSection.ScreenHistory)
            {
                <div class="card-head">
                    <h2>Screen History</h2>
                    <p>Automatically remember what's on your screen when you switch windows or tabs.</p>
                </div>

                <div class="field">
                    <label for="screenHistoryMode">Capture mode</label>
                    <select id="screenHistoryMode" @bind="_config.ScreenHistoryMode">
                        <option value="@ScreenHistoryMode.Disabled">Disabled</option>
                        <option value="@ScreenHistoryMode.TextOnly">Text only</option>
                        <option value="@ScreenHistoryMode.TextAndScreenshot">Text + screenshot</option>
                    </select>
                    <span class="hint">@ScreenHistoryModeHint(_config.ScreenHistoryMode)</span>
                </div>

                <div class="field">
                    <label>Chat attachments</label>
                    <label class="hint" style="display:flex;gap:8px;align-items:center;cursor:pointer">
                        <input type="checkbox" @bind="_config.RememberTaggedCaptures" />
                        Remember windows attached with @@ in chat
                    </label>
                    <span class="hint">When you attach a window to a prompt by typing @@, its capture is also
                        saved to memory so you can recall it later.</span>
                </div>

                <div class="field">
                    <label>Privacy</label>
                    <span class="hint">Everything stays on this machine: capture files in
                        <code>~/.floaty/captures</code>, the searchable index in <code>~/.floaty/floaty.db</code>.
                        Capture text (and screenshots, in that mode) is sent to your configured OpenAI models to
                        be embedded/described. Ask Floaty things like “what was I reading about X earlier?” to
                        search it.</span>
                </div>

                <div class="field">
                    <label>Stored history</label>
                    <div class="actions sub-actions">
                        @if (!_confirmClearHistory)
                        {
                            <button class="reload" @onclick="() => _confirmClearHistory = true" disabled="@_clearingHistory">
                                <i class="ti ti-trash" aria-hidden="true"></i>
                                <span>Clear screen history</span>
                            </button>
                        }
                        else
                        {
                            <button class="reload" @onclick="ClearScreenHistory" disabled="@_clearingHistory">
                                <i class="ti ti-alert-triangle" aria-hidden="true"></i>
                                <span>@(_clearingHistory ? "Clearing…" : "Yes, delete it all")</span>
                            </button>
                            <button class="reload" @onclick="() => _confirmClearHistory = false" disabled="@_clearingHistory">
                                <span>Cancel</span>
                            </button>
                        }
                        <span class="hint">@(_autoCaptureCount is int n ? $"{n} snapshot(s) stored." : "Counting…")</span>
                    </div>
                    <span class="hint">Deletes all automatic snapshots and their files. Captures you took
                        yourself (📷 or <code>/capture</code>) and saved notes are kept.</span>
                </div>
            }
            else if (_activeSection == SettingsSection.VoiceInput)
            {
                <div class="card-head">
                    <h2>Voice Input</h2>
                    <p>Dictate chat messages with a local, offline speech-to-text model.</p>
                </div>

                <div class="mcp-list">
                    <div class="mcp-row">
                        <input type="radio" name="sttModel" checked="@(_config.SttSelectedModelId is null)"
                               @onchange="() => SelectSttModel(null)" title="Voice input off" />
                        <div class="mcp-info">
                            <span class="mcp-name"><i class="ti ti-microphone-off" aria-hidden="true"></i> Off</span>
                            <span class="mcp-meta">No voice input; the mic button is hidden.</span>
                        </div>
                    </div>
                    @foreach (var model in SttModelCatalog.Models)
                    {
                        var downloaded = IsSttDownloaded(model);
                        <div class="mcp-row">
                            <input type="radio" name="sttModel" checked="@(_config.SttSelectedModelId == model.Id)"
                                   disabled="@(!downloaded)"
                                   @onchange="() => SelectSttModel(model.Id)" title="Use this model" />
                            <div class="mcp-info">
                                <span class="mcp-name"><i class="ti ti-microphone" aria-hidden="true"></i> @model.DisplayName</span>
                                <span class="mcp-meta">
                                    @if (model.IsAvailable)
                                    {
                                        @($"{model.SizeNote} · {model.LanguageNote}{(model.GpuRecommended ? " · GPU recommended" : "")}")
                                    }
                                    else
                                    {
                                        @("Coming soon")
                                    }
                                </span>
                            </div>
                            @if (!model.IsAvailable)
                            {
                                <!-- no actions for models we can't run yet -->
                            }
                            else if (_sttDownloading.Contains(model.Id))
                            {
                                <button class="mcp-remove" disabled>
                                    <i class="ti ti-download" aria-hidden="true"></i>
                                    <span>@($"{(int)(_sttProgress.GetValueOrDefault(model.Id) * 100)}%")</span>
                                </button>
                            }
                            else if (!downloaded)
                            {
                                <button class="mcp-remove" @onclick="() => DownloadSttModel(model)">
                                    <i class="ti ti-download" aria-hidden="true"></i>
                                    <span>Download</span>
                                </button>
                            }
                            else if (_confirmDeleteModelId == model.Id)
                            {
                                <button class="mcp-remove" @onclick="() => DeleteSttModel(model)">
                                    <i class="ti ti-alert-triangle" aria-hidden="true"></i>
                                    <span>Really delete?</span>
                                </button>
                                <button class="mcp-remove" @onclick="() => _confirmDeleteModelId = null">
                                    <span>Cancel</span>
                                </button>
                            }
                            else
                            {
                                <button class="mcp-remove" @onclick="() => _confirmDeleteModelId = model.Id">
                                    <i class="ti ti-trash" aria-hidden="true"></i>
                                    <span>Delete</span>
                                </button>
                            }
                        </div>
                    }
                </div>
                @if (_sttError is not null)
                {
                    <p class="hint">@_sttError</p>
                }
                <span class="hint">Models download to <code>~/.floaty/models</code> and run entirely on this
                    machine (GPU-accelerated where available), sharing a small speech engine (~26 MB)
                    fetched automatically with the first model. Downloads apply immediately; the selected
                    model and send mode apply on Save.</span>

                <div class="field">
                    <label for="voiceSendMode">Send mode</label>
                    <select id="voiceSendMode" @bind="_config.VoiceSendMode">
                        <option value="@VoiceSendMode.Manual">Manual — I press send myself</option>
                        <option value="@VoiceSendMode.AutoSendOnPause">Auto-send after a pause</option>
                    </select>
                    <span class="hint">@(_config.VoiceSendMode == VoiceSendMode.AutoSendOnPause
                        ? "After you stop speaking for the pause length below, the message sends automatically."
                        : "Dictated text lands in the chat box; press send when you're ready.")</span>
                </div>

                @if (_config.VoiceSendMode == VoiceSendMode.AutoSendOnPause)
                {
                    <div class="field">
                        <label for="voicePauseSeconds">Pause length (seconds)</label>
                        <input id="voicePauseSeconds" type="number" min="1" max="10" step="0.5"
                               @bind="_config.AutoSendPauseSeconds" />
                        <span class="hint">Silence this long after you finish speaking sends the message.</span>
                    </div>
                }
            }
            else if (_activeSection == SettingsSection.Mcp)
            {
                <div class="card-head">
                    <h2>MCP Servers</h2>
                    <p>Add Model Context Protocol servers. Each is callable in chat via <code>/name</code>.</p>
                </div>

                @if (_config.McpServers.Count == 0)
                {
                    <p class="hint">No servers configured yet.</p>
                }
                else
                {
                    <div class="mcp-list">
                        @foreach (var server in _config.McpServers)
                        {
                            <div class="mcp-row">
                                <input type="checkbox" @bind="server.Enabled" title="Enabled" />
                                <div class="mcp-info">
                                    <span class="mcp-name"><i class="ti ti-server-2" aria-hidden="true"></i> /@server.Name</span>
                                    <span class="mcp-meta">@server.Transport · @(server.Transport == "http" ? server.Url : server.Command)</span>
                                </div>
                                <button class="mcp-remove" @onclick="() => RemoveServer(server)">
                                    <i class="ti ti-trash" aria-hidden="true"></i>
                                    <span>Remove</span>
                                </button>
                            </div>
                        }
                    </div>
                }

                <div class="mcp-add">
                    <h3>Add server</h3>

                    <div class="field">
                        <label for="mcpName">Name</label>
                        <input id="mcpName" type="text" autocomplete="off" spellcheck="false" placeholder="github"
                               @bind="_newServer.Name" @bind:event="oninput" />
                        <span class="hint">Used as the <code>/name</code> slash command.</span>
                    </div>

                    <div class="field">
                        <label for="mcpTransport">Transport</label>
                        <select id="mcpTransport" @bind="_newServer.Transport">
                            <option value="stdio">stdio (local command)</option>
                            <option value="http">http (remote URL)</option>
                        </select>
                    </div>

                    @if (_newServer.Transport == "http")
                    {
                        <div class="field">
                            <label for="mcpUrl">URL</label>
                            <input id="mcpUrl" type="text" autocomplete="off" spellcheck="false"
                                   placeholder="https://example.com/mcp" @bind="_newServer.Url" @bind:event="oninput" />
                        </div>
                        <div class="field">
                            <label for="mcpHeaders">Headers</label>
                            <textarea id="mcpHeaders" rows="3" @bind="_newServerHeaders" @bind:event="oninput"></textarea>
                            <span class="hint">One <code>KEY=VALUE</code> per line (e.g. <code>Authorization=Bearer …</code>).</span>
                        </div>
                    }
                    else
                    {
                        <div class="field">
                            <label for="mcpCommand">Command</label>
                            <input id="mcpCommand" type="text" autocomplete="off" spellcheck="false" placeholder="npx"
                                   @bind="_newServer.Command" @bind:event="oninput" />
                        </div>
                        <div class="field">
                            <label for="mcpArgs">Arguments</label>
                            <textarea id="mcpArgs" rows="3" @bind="_newServerArgs" @bind:event="oninput"></textarea>
                            <span class="hint">One argument per line.</span>
                        </div>
                        <div class="field">
                            <label for="mcpEnv">Environment</label>
                            <textarea id="mcpEnv" rows="2" @bind="_newServerEnv" @bind:event="oninput"></textarea>
                            <span class="hint">One <code>KEY=VALUE</code> per line.</span>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_mcpError))
                    {
                        <p class="mcp-error">@_mcpError</p>
                    }

                    <button class="reload" @onclick="AddServer">
                        <i class="ti ti-plus" aria-hidden="true"></i>
                        <span>Add server</span>
                    </button>
                </div>
            }
            else if (_activeSection == SettingsSection.Exec)
            {
                <div class="card-head">
                    <h2>Shell</h2>
                    <p>Let Floaty run shell commands to create and edit files, launch apps, and automate your
                        computer. Off by default; every command must be approved by you before it runs.</p>
                </div>

                <div class="field">
                    <label>Command execution</label>
                    <label class="hint" style="display:flex;gap:8px;align-items:center;cursor:pointer">
                        <input type="checkbox" @bind="_config.ExecEnabled" />
                        Enable the shell command tool
                    </label>
                    <span class="hint">When enabled, Floaty can propose shell commands. Each one appears in the
                        overlay with the exact command and a Run / Cancel prompt — nothing executes until you
                        approve it.</span>
                </div>

                @if (_config.ExecEnabled)
                {
                    <div class="field">
                        <label for="execShell">Default shell</label>
                        <select id="execShell" @bind="_config.ExecShell">
                            <option value="@ExecShellKind.PowerShell">Windows PowerShell (powershell.exe)</option>
                            <option value="@ExecShellKind.Pwsh">PowerShell Core (pwsh)</option>
                            <option value="@ExecShellKind.Cmd">Command Prompt (cmd.exe)</option>
                            <option value="@ExecShellKind.Bash">bash</option>
                            <option value="@ExecShellKind.Zsh">zsh</option>
                            <option value="@ExecShellKind.Sh">sh</option>
                            <option value="@ExecShellKind.Custom">Custom…</option>
                        </select>
                        <span class="hint">The shell commands are run through.</span>
                    </div>

                    @if (_config.ExecShell == ExecShellKind.Custom)
                    {
                        <div class="field">
                            <label for="execCustomPath">Custom shell executable</label>
                            <input id="execCustomPath" type="text" autocomplete="off" spellcheck="false"
                                   placeholder="/usr/bin/fish" @bind="_config.ExecCustomShellPath"
                                   @bind:event="oninput" />
                            <span class="hint">Full path to the shell executable to launch.</span>
                        </div>

                        <div class="field">
                            <label for="execCustomArgs">Custom arguments</label>
                            <input id="execCustomArgs" type="text" autocomplete="off" spellcheck="false"
                                   placeholder="-c {command}" @bind="_config.ExecCustomShellArgs"
                                   @bind:event="oninput" />
                            <span class="hint">Arguments passed before the command. The <code>{command}</code>
                                token is replaced by the command text; if omitted, the command is appended as a
                                final argument.</span>
                        </div>
                    }
                }
            }
            else if (_activeSection == SettingsSection.Skills)
            {
                <div class="card-head">
                    <h2>Skills</h2>
                    <p>Agent skills (SKILL.md) from <code>~/.floaty/skills</code>, <code>~/.claude/skills</code> and
                       <code>~/.agents/skills</code>. Each enabled skill is callable in chat via <code>/name</code>.</p>
                </div>

                <div class="actions sub-actions">
                    <button class="reload" @onclick="ReloadSkills">
                        <i class="ti ti-refresh" aria-hidden="true"></i>
                        <span>Reload</span>
                    </button>
                    <button class="reload" @onclick="OpenSkillsFolder">
                        <i class="ti ti-folder" aria-hidden="true"></i>
                        <span>Open folder</span>
                    </button>
                    <span class="hint">Found @_skills.Count skill(s).</span>
                </div>

                @if (_skills.Count == 0)
                {
                    <p class="hint">No skills found. Drop a folder containing a <code>SKILL.md</code> into
                        <code>~/.floaty/skills</code> and click Reload.</p>
                }
                else
                {
                    <div class="mcp-list">
                        @foreach (var skill in _skills)
                        {
                            <div class="mcp-row">
                                <input type="checkbox" checked="@IsSkillEnabled(skill.Name)"
                                       @onchange="e => SetSkillEnabled(skill.Name, (bool)(e.Value ?? false))" title="Enabled" />
                                <div class="mcp-info">
                                    <span class="mcp-name"><i class="ti ti-bolt" aria-hidden="true"></i> /@skill.Name</span>
                                    <span class="mcp-meta">@(string.IsNullOrWhiteSpace(skill.Description) ? skill.SourcePath : skill.Description)</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
            else if (_activeSection == SettingsSection.Updates)
            {
                <div class="card-head">
                    <h2>Updates</h2>
                    <p>Keep Floaty up to date. New versions are published on GitHub.</p>
                </div>

                <div class="field">
                    <label>Current version</label>
                    <span class="hint">You are running <code>@UpdateService.CurrentVersion</code>.</span>
                </div>

                @if (!UpdateService.IsSupported)
                {
                    <p class="hint">
                        Automatic updates are only available in installed builds. Download the latest
                        release from the
                        <a href="#" @onclick="OpenReleasesPage" @onclick:preventDefault="true">releases page</a>.
                    </p>
                }
                else if (_updatePending)
                {
                    <p class="hint">An update to <code>@_latestVersion</code> has been downloaded and is
                        ready to install.</p>

                    <div class="actions">
                        <button class="save" @onclick="RestartAndUpdate">
                            <i class="ti ti-refresh" aria-hidden="true"></i>
                            <span>Restart &amp; update</span>
                        </button>
                    </div>
                }
                else
                {
                    <div class="actions sub-actions">
                        <button class="reload" @onclick="CheckForUpdates" disabled="@(_checking || _downloading)">
                            <i class="ti ti-cloud-download" aria-hidden="true"></i>
                            <span>@(_checking ? "Checking…" : "Check for updates")</span>
                        </button>
                        @if (!string.IsNullOrEmpty(_updateStatus))
                        {
                            <span class="hint">@_updateStatus</span>
                        }
                    </div>

                    @if (_updateAvailable)
                    {
                        <p class="hint">Version <code>@_latestVersion</code> is available.</p>

                        <div class="actions">
                            <button class="save" @onclick="DownloadUpdate" disabled="@_downloading">
                                <i class="ti ti-download" aria-hidden="true"></i>
                                <span>@(_downloading ? $"Downloading… {_downloadProgress}%" : "Download & install")</span>
                            </button>
                        </div>
                    }
                }

                @if (!string.IsNullOrWhiteSpace(_notesHtml))
                {
                    <div class="whats-new">
                        <h3>What's new@(string.IsNullOrEmpty(_latestVersion) ? string.Empty : $" in {_latestVersion}")</h3>
                        <div class="notes">@((MarkupString)_notesHtml)</div>
                    </div>
                }
            }
            else
                {
                    <div class="card-head">
                        <h2>AI Provider</h2>
                        <p>Floaty uses this provider to answer your chats.</p>
                    </div>

                    <div class="field">
                        <label>Provider</label>
                        <select @bind="_config.Provider" disabled>
                            <option value="OpenAI">OpenAI</option>
                        </select>
                        <span class="hint">More providers coming soon.</span>
                    </div>

                    <div class="field">
                        <label for="apiKey">API key</label>
                        <input id="apiKey" type="password" autocomplete="off" spellcheck="false" placeholder="sk-..."
                               @bind="_config.OpenAiApiKey" @bind:event="oninput" />
                        <span class="hint">Stored locally in <code>~/.floaty/config.json</code>. Never leaves your machine
                            except to call OpenAI.</span>
                        </div>

                        <div class="field">
                            <label for="model">Model</label>
                            <input id="model" type="text" autocomplete="off" spellcheck="false" @bind="_config.Model"
                                   @bind:event="oninput" />
                            <span class="hint">e.g. <code>gpt-4o-mini</code>, <code>gpt-4o</code>.</span>
                        </div>

                        <div class="field">
                            <label for="embeddingModel">Embedding model</label>
                            <input id="embeddingModel" type="text" autocomplete="off" spellcheck="false"
                                   @bind="_config.EmbeddingModel" @bind:event="oninput" />
                            <span class="hint">Used to vectorize captures for search. e.g.
                                <code>text-embedding-3-small</code>.</span>
                            </div>

                        <div class="field">
                            <label for="snapshotModel">Snapshot model</label>
                            <input id="snapshotModel" type="text" autocomplete="off" spellcheck="false"
                                   @bind="_config.SnapshotModel" @bind:event="oninput" />
                            <span class="hint">Vision model used to describe captured screenshots. Leave
                                blank to disable. e.g. <code>gpt-4o-mini</code>.</span>
                            </div>
                        }

                        <div class="actions">
                            <button class="save" @onclick="Save">
                                <i class="ti ti-device-floppy" aria-hidden="true"></i>
                                <span>Save</span>
                            </button>
                            @if (_saved)
                            {
                                <span class="saved">Saved</span>
                            }
                        </div>
                    </div>
                </section>
            </div>

@code {
    private const string DefaultSystemPrompt =
        "You are Floaty, a desktop assistant that lives in a floating overlay. The user can capture " +
        "what's on their screen, and Floaty may also snapshot windows automatically as the user switches " +
        "between them (screen history); both are stored in local memory. When the user asks about " +
        "something they previously saw, viewed, read, or captured — or about their earlier activity — " +
        "call the search_captures tool to retrieve it before answering, and ground your answer in what " +
        "it returns. Be concise.";

    private enum SettingsSection
    {
        Behavior,
        Appearance,
        ModelProvider,
        ScreenHistory,
        VoiceInput,
        Mcp,
        Exec,
        Skills,
        Updates,
    }

    private sealed record RingImageOption(string Value, string Label, bool IsBuiltIn, string? PreviewSrc = null);

    private static readonly (string Label, string Value)[] AccentPresets =
    [
        ("Blue", "#2b7fff"),
        ("Indigo", "#6366f1"),
        ("Violet", "#8b5cf6"),
        ("Pink", "#ec4899"),
        ("Red", "#ef4444"),
        ("Orange", "#f97316"),
        ("Green", "#22c55e"),
        ("Teal", "#14b8a6"),
    ];

    private FloatyConfig _config = new();
    private string _systemPrompt = string.Empty;
    private List<RingImageOption> _ringOptions = new();
    private int _customRingCount;
    private bool _saved;
    private SettingsSection _activeSection = SettingsSection.Behavior;

    // Add-MCP-server form state. Args/Env/Headers are edited as text and parsed on Add.
    private McpServerConfig _newServer = new();
    private string _newServerArgs = string.Empty;
    private string _newServerEnv = string.Empty;
    private string _newServerHeaders = string.Empty;
    private string? _mcpError;

    // Discovered agent skills (metadata); enable state is tracked via _config.DisabledSkills.
    private List<FloatySkill> _skills = new();

    // Screen history section state. The count loads lazily when the section is opened.
    private int? _autoCaptureCount;
    private bool _confirmClearHistory;
    private bool _clearingHistory;

    // Voice input section state. Downloads mutate disk immediately; selection/mode commit on Save.
    private readonly HashSet<string> _sttDownloading = new();
    private readonly Dictionary<string, double> _sttProgress = new();
    private string? _sttError;
    private string? _confirmDeleteModelId;

    // Update section state.
    private bool _checking;
    private bool _downloading;
    private bool _updateAvailable;
    private bool _updatePending;
    private int _downloadProgress;
    private string? _latestVersion;
    private string? _updateStatus;
    private string? _notesHtml;

    protected override async Task OnInitializedAsync()
    {
        // Work on a copy so edits aren't committed until the user clicks Save.
        var current = ConfigService.Current;
        _config = new FloatyConfig
        {
            Provider = current.Provider,
            OpenAiApiKey = current.OpenAiApiKey,
            Model = current.Model,
            EmbeddingModel = current.EmbeddingModel,
            SnapshotModel = current.SnapshotModel,
            RingImageFileName = current.RingImageFileName,
            RingSize = current.RingSize,
            AccentColor = current.AccentColor,
            ScreenHistoryMode = current.ScreenHistoryMode,
            AutostartMode = current.AutostartMode,
            RememberTaggedCaptures = current.RememberTaggedCaptures,
            McpServers = current.McpServers.Select(CloneServer).ToList(),
            DisabledSkills = new List<string>(current.DisabledSkills),
            SttSelectedModelId = current.SttSelectedModelId,
            VoiceSendMode = current.VoiceSendMode,
            AutoSendPauseSeconds = current.AutoSendPauseSeconds,
            ExecEnabled = current.ExecEnabled,
            ExecShell = current.ExecShell,
            ExecCustomShellPath = current.ExecCustomShellPath,
            ExecCustomShellArgs = current.ExecCustomShellArgs,
        };

        _systemPrompt = ConfigService.GetSystemPrompt(DefaultSystemPrompt);
        _skills = SkillService.Skills.ToList();

        // A background startup check may have already downloaded an update; surface its notes.
        _updatePending = UpdateService.IsUpdatePending;
        if (_updatePending)
        {
            _latestVersion = UpdateService.PendingVersion;
            _notesHtml = UpdateService.PendingNotesHtml;
        }

        await ReloadRingImages();
    }

    private async Task CheckForUpdates()
    {
        _checking = true;
        _updateStatus = null;
        _updateAvailable = false;
        _notesHtml = null;
        StateHasChanged();

        var result = await UpdateService.CheckAsync();

        _checking = false;
        if (result.Error is not null)
        {
            _updateStatus = result.Error;
        }
        else if (result.UpdateAvailable)
        {
            _updateAvailable = true;
            _latestVersion = result.TargetVersion;
            _notesHtml = result.NotesHtml;
        }
        else
        {
            _updateStatus = "You're up to date.";
        }

        StateHasChanged();
    }

    private async Task DownloadUpdate()
    {
        _downloading = true;
        _downloadProgress = 0;
        StateHasChanged();

        var progress = new Progress<int>(p =>
        {
            _downloadProgress = p;
            InvokeAsync(StateHasChanged);
        });

        try
        {
            await UpdateService.DownloadAsync(progress);
            _updatePending = UpdateService.IsUpdatePending;
        }
        catch (Exception ex)
        {
            _updateStatus = ex.Message;
        }

        _downloading = false;
        _updateAvailable = false;
        StateHasChanged();
    }

    private void RestartAndUpdate() => UpdateService.ApplyAndRestart();

    private bool IsSttDownloaded(SttModelInfo model) => model.IsAvailable && ModelDownloads.IsDownloaded(model);

    private void SelectSttModel(string? modelId)
    {
        _config.SttSelectedModelId = modelId;
        _saved = false;
    }

    private async Task DownloadSttModel(SttModelInfo model)
    {
        _sttError = null;
        _sttDownloading.Add(model.Id);
        _sttProgress[model.Id] = 0;
        StateHasChanged();

        var progress = new Progress<double>(p =>
        {
            _sttProgress[model.Id] = p;
            InvokeAsync(StateHasChanged);
        });

        try
        {
            await ModelDownloads.DownloadAsync(model, progress);
        }
        catch (Exception ex)
        {
            _sttError = $"Download failed: {ex.Message}";
        }

        _sttDownloading.Remove(model.Id);
        StateHasChanged();
    }

    private void DeleteSttModel(SttModelInfo model)
    {
        _confirmDeleteModelId = null;
        ModelDownloads.Delete(model);
        if (_config.SttSelectedModelId == model.Id)
            _config.SttSelectedModelId = null;

        // Deleting files takes effect immediately, so if the saved config still points at this
        // model, clear it right away (not on Save) — a dangling selection would keep claiming
        // voice input is configured while nothing is on disk.
        if (ConfigService.Current.SttSelectedModelId == model.Id)
        {
            ConfigService.Current.SttSelectedModelId = null;
            ConfigService.Save(ConfigService.Current);
        }
    }

    private async Task OpenReleasesPage()
    {
        try
        {
            await Microsoft.Maui.ApplicationModel.Launcher.Default.OpenAsync(UpdateService.ReleasesUrl);
        }
        catch
        {
            // Opening the browser is best-effort.
        }
    }

    private void Save()
    {
        ConfigService.Save(_config);
        ConfigService.SaveSystemPrompt(_systemPrompt);
        _saved = true;
    }

    private bool IsSkillEnabled(string name) =>
        !_config.DisabledSkills.Contains(name, StringComparer.OrdinalIgnoreCase);

    private void SetSkillEnabled(string name, bool enabled)
    {
        _config.DisabledSkills.RemoveAll(n => string.Equals(n, name, StringComparison.OrdinalIgnoreCase));
        if (!enabled)
            _config.DisabledSkills.Add(name);
        _saved = false;
    }

    private void ReloadSkills()
    {
        SkillService.Reload();
        _skills = SkillService.Skills.ToList();
        _saved = false;
    }

    private async Task OpenSkillsFolder()
    {
        try
        {
            var uri = new UriBuilder(Uri.UriSchemeFile, string.Empty) { Path = FloatyPaths.Skills }.Uri;
            await Microsoft.Maui.ApplicationModel.Launcher.Default.OpenAsync(uri);
        }
        catch
        {
            // Opening the folder is best-effort.
        }
    }

    private void AddServer()
    {
        var name = _newServer.Name?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(name))
        {
            _mcpError = "Name is required.";
            return;
        }

        if (_config.McpServers.Any(s => string.Equals(s.Name, name, StringComparison.OrdinalIgnoreCase)))
        {
            _mcpError = $"A server named '{name}' already exists.";
            return;
        }

        var server = new McpServerConfig
        {
            Name = name,
            Transport = _newServer.Transport,
            Enabled = true,
        };

        if (string.Equals(server.Transport, "http", StringComparison.OrdinalIgnoreCase))
        {
            server.Url = _newServer.Url?.Trim() ?? string.Empty;
            server.Headers = ParsePairs(_newServerHeaders);
        }
        else
        {
            server.Command = _newServer.Command?.Trim() ?? string.Empty;
            server.Args = ParseLines(_newServerArgs);
            server.Env = ParsePairs(_newServerEnv);
        }

        _config.McpServers.Add(server);

        _newServer = new McpServerConfig();
        _newServerArgs = _newServerEnv = _newServerHeaders = string.Empty;
        _mcpError = null;
        _saved = false;
    }

    private void RemoveServer(McpServerConfig server)
    {
        _config.McpServers.Remove(server);
        _saved = false;
    }

    private static McpServerConfig CloneServer(McpServerConfig s) => new()
    {
        Name = s.Name,
        Transport = s.Transport,
        Enabled = s.Enabled,
        Command = s.Command,
        Args = new List<string>(s.Args),
        Env = new Dictionary<string, string>(s.Env),
        Url = s.Url,
        Headers = new Dictionary<string, string>(s.Headers),
    };

    private static List<string> ParseLines(string? text) =>
        string.IsNullOrWhiteSpace(text)
            ? new List<string>()
            : text.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();

    private static Dictionary<string, string> ParsePairs(string? text)
    {
        var result = new Dictionary<string, string>();
        if (string.IsNullOrWhiteSpace(text))
            return result;

        foreach (var line in text.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            var index = line.IndexOf('=');
            if (index <= 0)
                continue;
            var key = line[..index].Trim();
            if (key.Length > 0)
                result[key] = line[(index + 1)..].Trim();
        }

        return result;
    }

    private async Task ReloadRingImages()
    {
        var customImages = ConfigService.GetAvailableRingImages().ToList();
        var builtInImages = ConfigService
            .GetBuiltInRingImages()
            .OrderBy(name => name, StringComparer.OrdinalIgnoreCase)
            .ToList();


        var builtInOptions = new List<RingImageOption>();
        foreach (var name in builtInImages)
        {
            var preview = await ConfigService.GetBuiltInRingImageDataUrlAsync(name);
            builtInOptions.Add(new RingImageOption(name, name, true, preview));
        }

        var customOptions = new List<RingImageOption>();
        foreach (var name in customImages)
        {
            var preview = await ConfigService.GetRingImageDataUrlAsync(name);
            customOptions.Add(new RingImageOption(name, name, false, preview));
        }

        _ringOptions =
        [
            .. builtInOptions,
            .. customOptions,
        ];

        _customRingCount = customImages.Count;

        if (!ConfigService.IsValidRingSelection(_config.RingImageFileName))
        {
            _config.RingImageFileName = string.Empty;
        }

        _saved = false;
    }

    private void SelectRing(string value)
    {
        if (string.Equals(_config.RingImageFileName, value, StringComparison.OrdinalIgnoreCase))
            return;

        _config.RingImageFileName = value;
        _saved = false;
    }

    // Live-preview the ring size on the overlay as the slider moves; committed only on Save.
    private void OnRingSizeInput(ChangeEventArgs e)
    {
        var raw = Convert.ToString(e.Value, System.Globalization.CultureInfo.InvariantCulture);
        if (!double.TryParse(raw, System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var size))
            return;

        _config.RingSize = SettingsService.ClampRingSize(size);
        _saved = false;
        ConfigService.PreviewRingSize(_config.RingSize);
    }

    private bool IsSelectedAccent(string value) =>
        string.Equals(_config.AccentColor, value, StringComparison.OrdinalIgnoreCase);

    // Live-preview the accent on the overlay as the user picks; committed only on Save.
    private void SelectAccent(string value)
    {
        _config.AccentColor = SettingsService.NormalizeAccentColor(value);
        _saved = false;
        ConfigService.PreviewAccentColor(_config.AccentColor);
    }

    private void OnAccentColorInput(ChangeEventArgs e) =>
        SelectAccent(Convert.ToString(e.Value, System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty);

    // If the settings window closes without saving, revert any live previews (ring size, accent)
    // to the persisted values so the overlay doesn't keep uncommitted state.
    public void Dispose()
    {
        ConfigService.PreviewRingSize(ConfigService.Current.RingSize);
        ConfigService.PreviewAccentColor(ConfigService.Current.AccentColor);
    }

    private bool IsSelectedRing(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.IsNullOrWhiteSpace(_config.RingImageFileName);

        return string.Equals(_config.RingImageFileName, value, StringComparison.OrdinalIgnoreCase);
    }

    private void SelectSection(SettingsSection section)
    {
        _activeSection = section;
        _saved = false;

        if (section == SettingsSection.ScreenHistory)
        {
            _confirmClearHistory = false;
            _autoCaptureCount = null;
            _ = LoadAutoCaptureCountAsync();
        }
    }

    private static string AutostartModeHint(AutostartMode mode) => mode switch
    {
        AutostartMode.Disabled => "Floaty only runs when you launch it yourself.",
        AutostartMode.Minimized => "Floaty starts hidden when you sign in — summon it with Alt+F or the tray icon.",
        _ => "The floating ring appears as soon as you sign in.",
    };

    private static string ScreenHistoryModeHint(ScreenHistoryMode mode) => mode switch
    {
        ScreenHistoryMode.Disabled => "Nothing is recorded.",
        ScreenHistoryMode.TextOnly => "When you settle on a window or tab, its visible text is saved to " +
            "local memory (one embedding call per snapshot). No screenshots.",
        _ => "Also saves a PNG of the window; if a Snapshot model is set, it describes the image " +
            "(adds a vision call per snapshot).",
    };

    private async Task LoadAutoCaptureCountAsync()
    {
        try
        {
            _autoCaptureCount = await MemoryService.CountAutoCapturesAsync();
        }
        catch
        {
            _autoCaptureCount = 0; // a fresh install has no database yet
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task ClearScreenHistory()
    {
        _clearingHistory = true;
        try
        {
            await MemoryService.DeleteAutoCapturesAsync();
            _autoCaptureCount = 0;
        }
        catch
        {
            // Best-effort; the count reload below reflects whatever actually happened.
            _ = LoadAutoCaptureCountAsync();
        }

        _clearingHistory = false;
        _confirmClearHistory = false;
    }

    private string TabClass(SettingsSection section) => section == _activeSection ? "active" : string.Empty;
}

<style>
