@inject SettingsService ConfigService

<div class="settings">
    <header class="settings-header">
        <h1><i class="ti ti-settings" aria-hidden="true"></i> Settings</h1>
        <p class="subtitle">Configure Floaty behavior and AI provider options.</p>
    </header>

    <section class="settings-panel">
        <aside class="tabs" aria-label="Settings sections">
            <button class="tab @TabClass(SettingsSection.Behavior)"
                    @onclick="() => SelectSection(SettingsSection.Behavior)">
                <i class="ti ti-message-chatbot" aria-hidden="true"></i>
                <span>Behavior</span>
            </button>
            <button class="tab @TabClass(SettingsSection.Appearance)"
                    @onclick="() => SelectSection(SettingsSection.Appearance)">
                <i class="ti ti-palette" aria-hidden="true"></i>
                <span>Appearance</span>
            </button>
            <button class="tab @TabClass(SettingsSection.ModelProvider)"
                    @onclick="() => SelectSection(SettingsSection.ModelProvider)">
                <i class="ti ti-cpu" aria-hidden="true"></i>
                <span>Model Provider</span>
            </button>
            <button class="tab @TabClass(SettingsSection.Mcp)"
                    @onclick="() => SelectSection(SettingsSection.Mcp)">
                <i class="ti ti-server-2" aria-hidden="true"></i>
                <span>MCP Servers</span>
            </button>
        </aside>

        <div class="card">
            @if (_activeSection == SettingsSection.Behavior)
            {
                <div class="card-head">
                    <h2>Behavior</h2>
                    <p>Define Floaty's system prompt used at the start of every chat.</p>
                </div>

                <div class="field">
                    <label for="systemPrompt">System prompt</label>
                    <textarea id="systemPrompt" rows="12" autocomplete="off" spellcheck="false" @bind="_systemPrompt"
                              @bind:event="oninput"></textarea>
                    <span class="hint">Saved locally to <code>~/.floaty/floaty.md</code>.</span>
                </div>
            }
            else if (_activeSection == SettingsSection.Appearance)
            {
                <div class="card-head">
                    <h2>Appearance</h2>
                    <p>Choose the ring image used by the floating overlay.</p>
                </div>

                <div class="field">
                    <label>Ring image</label>

                    <div class="ring-strip" role="list" aria-label="Ring image options">
                        @foreach (var option in _ringOptions)
                        {
                            <button type="button" role="listitem"
                                    class="ring-option @(IsSelectedRing(option.Value) ? "selected" : string.Empty)"
                                    title="@option.Label" @onclick="() => SelectRing(option.Value)">
                                <span class="ring-preview">
                                    @if (!string.IsNullOrWhiteSpace(option.PreviewSrc))
                                    {
                                        <img src="@option.PreviewSrc" alt="@option.Label" loading="lazy" />
                                    }
                                    else
                                    {
                                        <span class="ring-fallback">@option.Label[..1].ToUpperInvariant()</span>
                                    }
                                </span>
                                <span class="ring-name">@option.Label</span>
                                <span class="ring-kind">@(option.IsBuiltIn ? "Built-in" : "Custom")</span>
                            </button>
                        }
                    </div>

                    <span class="hint">
                        Built-ins come from app resources. Add your own images to <code>~/.floaty/ring</code> and click
                        Reload.
                    </span>
                </div>

                <div class="actions sub-actions">
                    <button class="reload" @onclick="ReloadRingImages">
                        <i class="ti ti-refresh" aria-hidden="true"></i>
                        <span>Reload</span>
                    </button>
                    <span class="hint">Loaded @_ringOptions.Count option(s), including @_customRingCount custom
                        image(s).</span>
                    </div>
                }
            else if (_activeSection == SettingsSection.Mcp)
            {
                <div class="card-head">
                    <h2>MCP Servers</h2>
                    <p>Add Model Context Protocol servers. Each is callable in chat via <code>/name</code>.</p>
                </div>

                @if (_config.McpServers.Count == 0)
                {
                    <p class="hint">No servers configured yet.</p>
                }
                else
                {
                    <div class="mcp-list">
                        @foreach (var server in _config.McpServers)
                        {
                            <div class="mcp-row">
                                <input type="checkbox" @bind="server.Enabled" title="Enabled" />
                                <div class="mcp-info">
                                    <span class="mcp-name"><i class="ti ti-server-2" aria-hidden="true"></i> /@server.Name</span>
                                    <span class="mcp-meta">@server.Transport · @(server.Transport == "http" ? server.Url : server.Command)</span>
                                </div>
                                <button class="mcp-remove" @onclick="() => RemoveServer(server)">
                                    <i class="ti ti-trash" aria-hidden="true"></i>
                                    <span>Remove</span>
                                </button>
                            </div>
                        }
                    </div>
                }

                <div class="mcp-add">
                    <h3>Add server</h3>

                    <div class="field">
                        <label for="mcpName">Name</label>
                        <input id="mcpName" type="text" autocomplete="off" spellcheck="false" placeholder="github"
                               @bind="_newServer.Name" @bind:event="oninput" />
                        <span class="hint">Used as the <code>/name</code> slash command.</span>
                    </div>

                    <div class="field">
                        <label for="mcpTransport">Transport</label>
                        <select id="mcpTransport" @bind="_newServer.Transport">
                            <option value="stdio">stdio (local command)</option>
                            <option value="http">http (remote URL)</option>
                        </select>
                    </div>

                    @if (_newServer.Transport == "http")
                    {
                        <div class="field">
                            <label for="mcpUrl">URL</label>
                            <input id="mcpUrl" type="text" autocomplete="off" spellcheck="false"
                                   placeholder="https://example.com/mcp" @bind="_newServer.Url" @bind:event="oninput" />
                        </div>
                        <div class="field">
                            <label for="mcpHeaders">Headers</label>
                            <textarea id="mcpHeaders" rows="3" @bind="_newServerHeaders" @bind:event="oninput"></textarea>
                            <span class="hint">One <code>KEY=VALUE</code> per line (e.g. <code>Authorization=Bearer …</code>).</span>
                        </div>
                    }
                    else
                    {
                        <div class="field">
                            <label for="mcpCommand">Command</label>
                            <input id="mcpCommand" type="text" autocomplete="off" spellcheck="false" placeholder="npx"
                                   @bind="_newServer.Command" @bind:event="oninput" />
                        </div>
                        <div class="field">
                            <label for="mcpArgs">Arguments</label>
                            <textarea id="mcpArgs" rows="3" @bind="_newServerArgs" @bind:event="oninput"></textarea>
                            <span class="hint">One argument per line.</span>
                        </div>
                        <div class="field">
                            <label for="mcpEnv">Environment</label>
                            <textarea id="mcpEnv" rows="2" @bind="_newServerEnv" @bind:event="oninput"></textarea>
                            <span class="hint">One <code>KEY=VALUE</code> per line.</span>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_mcpError))
                    {
                        <p class="mcp-error">@_mcpError</p>
                    }

                    <button class="reload" @onclick="AddServer">
                        <i class="ti ti-plus" aria-hidden="true"></i>
                        <span>Add server</span>
                    </button>
                </div>
            }
            else
                {
                    <div class="card-head">
                        <h2>AI Provider</h2>
                        <p>Floaty uses this provider to answer your chats.</p>
                    </div>

                    <div class="field">
                        <label>Provider</label>
                        <select @bind="_config.Provider" disabled>
                            <option value="OpenAI">OpenAI</option>
                        </select>
                        <span class="hint">More providers coming soon.</span>
                    </div>

                    <div class="field">
                        <label for="apiKey">API key</label>
                        <input id="apiKey" type="password" autocomplete="off" spellcheck="false" placeholder="sk-..."
                               @bind="_config.OpenAiApiKey" @bind:event="oninput" />
                        <span class="hint">Stored locally in <code>~/.floaty/config.json</code>. Never leaves your machine
                            except to call OpenAI.</span>
                        </div>

                        <div class="field">
                            <label for="model">Model</label>
                            <input id="model" type="text" autocomplete="off" spellcheck="false" @bind="_config.Model"
                                   @bind:event="oninput" />
                            <span class="hint">e.g. <code>gpt-4o-mini</code>, <code>gpt-4o</code>.</span>
                        </div>

                        <div class="field">
                            <label for="embeddingModel">Embedding model</label>
                            <input id="embeddingModel" type="text" autocomplete="off" spellcheck="false"
                                   @bind="_config.EmbeddingModel" @bind:event="oninput" />
                            <span class="hint">Used to vectorize captures for search. e.g.
                                <code>text-embedding-3-small</code>.</span>
                            </div>

                        <div class="field">
                            <label for="snapshotModel">Snapshot model</label>
                            <input id="snapshotModel" type="text" autocomplete="off" spellcheck="false"
                                   @bind="_config.SnapshotModel" @bind:event="oninput" />
                            <span class="hint">Vision model used to describe captured screenshots. Leave
                                blank to disable. e.g. <code>gpt-4o-mini</code>.</span>
                            </div>
                        }

                        <div class="actions">
                            <button class="save" @onclick="Save">
                                <i class="ti ti-device-floppy" aria-hidden="true"></i>
                                <span>Save</span>
                            </button>
                            @if (_saved)
                            {
                                <span class="saved">Saved</span>
                            }
                        </div>
                    </div>
                </section>
            </div>

@code {
    private const string DefaultSystemPrompt =
        "You are Floaty, a desktop assistant that lives in a floating overlay. The user can capture " +
        "what's on their screen; each capture's on-screen text is stored in local memory. When the user " +
        "asks about something they previously saw, viewed, read, or captured, call the search_captures " +
        "tool to retrieve it before answering, and ground your answer in what it returns. Be concise.";

    private enum SettingsSection
    {
        Behavior,
        Appearance,
        ModelProvider,
        Mcp,
    }

    private sealed record RingImageOption(string Value, string Label, bool IsBuiltIn, string? PreviewSrc = null);

    private FloatyConfig _config = new();
    private string _systemPrompt = string.Empty;
    private List<RingImageOption> _ringOptions = new();
    private int _customRingCount;
    private bool _saved;
    private SettingsSection _activeSection = SettingsSection.Behavior;

    // Add-MCP-server form state. Args/Env/Headers are edited as text and parsed on Add.
    private McpServerConfig _newServer = new();
    private string _newServerArgs = string.Empty;
    private string _newServerEnv = string.Empty;
    private string _newServerHeaders = string.Empty;
    private string? _mcpError;

    protected override async Task OnInitializedAsync()
    {
        // Work on a copy so edits aren't committed until the user clicks Save.
        var current = ConfigService.Current;
        _config = new FloatyConfig
        {
            Provider = current.Provider,
            OpenAiApiKey = current.OpenAiApiKey,
            Model = current.Model,
            EmbeddingModel = current.EmbeddingModel,
            SnapshotModel = current.SnapshotModel,
            RingImageFileName = current.RingImageFileName,
            McpServers = current.McpServers.Select(CloneServer).ToList(),
        };

        _systemPrompt = ConfigService.GetSystemPrompt(DefaultSystemPrompt);
        await ReloadRingImages();
    }

    private void Save()
    {
        ConfigService.Save(_config);
        ConfigService.SaveSystemPrompt(_systemPrompt);
        _saved = true;
    }

    private void AddServer()
    {
        var name = _newServer.Name?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(name))
        {
            _mcpError = "Name is required.";
            return;
        }

        if (_config.McpServers.Any(s => string.Equals(s.Name, name, StringComparison.OrdinalIgnoreCase)))
        {
            _mcpError = $"A server named '{name}' already exists.";
            return;
        }

        var server = new McpServerConfig
        {
            Name = name,
            Transport = _newServer.Transport,
            Enabled = true,
        };

        if (string.Equals(server.Transport, "http", StringComparison.OrdinalIgnoreCase))
        {
            server.Url = _newServer.Url?.Trim() ?? string.Empty;
            server.Headers = ParsePairs(_newServerHeaders);
        }
        else
        {
            server.Command = _newServer.Command?.Trim() ?? string.Empty;
            server.Args = ParseLines(_newServerArgs);
            server.Env = ParsePairs(_newServerEnv);
        }

        _config.McpServers.Add(server);

        _newServer = new McpServerConfig();
        _newServerArgs = _newServerEnv = _newServerHeaders = string.Empty;
        _mcpError = null;
        _saved = false;
    }

    private void RemoveServer(McpServerConfig server)
    {
        _config.McpServers.Remove(server);
        _saved = false;
    }

    private static McpServerConfig CloneServer(McpServerConfig s) => new()
    {
        Name = s.Name,
        Transport = s.Transport,
        Enabled = s.Enabled,
        Command = s.Command,
        Args = new List<string>(s.Args),
        Env = new Dictionary<string, string>(s.Env),
        Url = s.Url,
        Headers = new Dictionary<string, string>(s.Headers),
    };

    private static List<string> ParseLines(string? text) =>
        string.IsNullOrWhiteSpace(text)
            ? new List<string>()
            : text.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();

    private static Dictionary<string, string> ParsePairs(string? text)
    {
        var result = new Dictionary<string, string>();
        if (string.IsNullOrWhiteSpace(text))
            return result;

        foreach (var line in text.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            var index = line.IndexOf('=');
            if (index <= 0)
                continue;
            var key = line[..index].Trim();
            if (key.Length > 0)
                result[key] = line[(index + 1)..].Trim();
        }

        return result;
    }

    private async Task ReloadRingImages()
    {
        var customImages = ConfigService.GetAvailableRingImages().ToList();
        var builtInImages = ConfigService
            .GetBuiltInRingImages()
            .OrderBy(name => name, StringComparer.OrdinalIgnoreCase)
            .ToList();


        var builtInOptions = new List<RingImageOption>();
        foreach (var name in builtInImages)
        {
            var preview = await ConfigService.GetBuiltInRingImageDataUrlAsync(name);
            builtInOptions.Add(new RingImageOption(name, name, true, preview));
        }

        var customOptions = new List<RingImageOption>();
        foreach (var name in customImages)
        {
            var preview = await ConfigService.GetRingImageDataUrlAsync(name);
            customOptions.Add(new RingImageOption(name, name, false, preview));
        }

        _ringOptions =
        [
            .. builtInOptions,
            .. customOptions,
        ];

        _customRingCount = customImages.Count;

        if (!ConfigService.IsValidRingSelection(_config.RingImageFileName))
        {
            _config.RingImageFileName = string.Empty;
        }

        _saved = false;
    }

    private void SelectRing(string value)
    {
        if (string.Equals(_config.RingImageFileName, value, StringComparison.OrdinalIgnoreCase))
            return;

        _config.RingImageFileName = value;
        _saved = false;
    }

    private bool IsSelectedRing(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.IsNullOrWhiteSpace(_config.RingImageFileName);

        return string.Equals(_config.RingImageFileName, value, StringComparison.OrdinalIgnoreCase);
    }

    private void SelectSection(SettingsSection section)
    {
        _activeSection = section;
        _saved = false;
    }

    private string TabClass(SettingsSection section) => section == _activeSection ? "active" : string.Empty;
}

<style>
    .settings {
        max-width: 980px;
        margin: 0 auto;
        padding: 24px 28px 40px;
        font-family: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
        color: #1c1c1e;
    }

    .settings-header h1 {
        font-size: 24px;
        font-weight: 600;
        margin: 0 0 4px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .settings-header h1 .ti {
        font-size: 26px;
        line-height: 1;
        color: #2b7fff;
    }

    .settings-header .subtitle {
        margin: 0 0 24px;
        color: #6b6b70;
        font-size: 14px;
    }

    .settings-panel {
        display: grid;
        grid-template-columns: 210px 1fr;
        gap: 16px;
        align-items: start;
    }

    .tabs {
        border: 1px solid #e4e4e8;
        border-radius: 12px;
        background: #fff;
        padding: 10px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
    }

    .tab {
        border: 1px solid transparent;
        border-radius: 8px;
        background: #f7f7fa;
        color: #2d2d31;
        font-size: 14px;
        font-weight: 600;
        padding: 10px 12px;
        text-align: left;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 9px;
        transition: background .15s, border-color .15s, color .15s;
    }

    .tab .ti {
        font-size: 18px;
        line-height: 1;
        color: #8a8a90;
        transition: color .15s;
    }

    .tab.active .ti {
        color: #0f53bd;
    }

    .tab:hover {
        background: #efeff5;
    }

    .tab.active {
        background: #edf4ff;
        border-color: #bfd6ff;
        color: #0f53bd;
    }

    .card {
        border: 1px solid #e4e4e8;
        border-radius: 12px;
        padding: 20px 22px;
        background: #fff;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
    }

    .card-head h2 {
        font-size: 16px;
        font-weight: 600;
        margin: 0 0 2px;
    }

    .card-head p {
        margin: 0 0 18px;
        color: #6b6b70;
        font-size: 13px;
    }

    .field {
        display: flex;
        flex-direction: column;
        margin-bottom: 18px;
    }

    .field label {
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 6px;
    }

    .field input,
    .field select {
        font-size: 14px;
        padding: 9px 11px;
        border: 1px solid #d3d3d9;
        border-radius: 8px;
        background: #fafafa;
        outline: none;
        transition: border-color .15s, box-shadow .15s;
    }

    .field textarea {
        min-height: 220px;
        resize: vertical;
        font-size: 13px;
        line-height: 1.4;
        padding: 10px 11px;
        border: 1px solid #d3d3d9;
        border-radius: 8px;
        background: #fafafa;
        outline: none;
        font-family: Consolas, 'Courier New', monospace;
        transition: border-color .15s, box-shadow .15s;
    }

    .field input:focus,
    .field textarea:focus {
        border-color: #2b7fff;
        box-shadow: 0 0 0 3px rgba(43, 127, 255, 0.15);
        background: #fff;
    }

    .field .hint {
        font-size: 12px;
        color: #8a8a90;
        margin-top: 6px;
    }

    .field code {
        background: #f1f1f4;
        padding: 1px 5px;
        border-radius: 4px;
        font-size: 12px;
    }

    .actions {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 4px;
    }

    .save {
        background: #2b7fff;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 9px 20px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        transition: background .15s;
    }

    .save .ti,
    .reload .ti,
    .mcp-remove .ti {
        font-size: 16px;
        line-height: 1;
    }

    .save:hover {
        background: #1f6ae0;
    }

    .reload {
        background: #f1f4ff;
        color: #1749a3;
        border: 1px solid #c9d8ff;
        border-radius: 8px;
        padding: 8px 14px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 7px;
    }

    .reload:hover {
        background: #e8efff;
    }

    .sub-actions {
        margin-top: -2px;
        margin-bottom: 12px;
    }

    .ring-strip {
        display: flex;
        gap: 10px;
        overflow-x: auto;
        padding: 4px 2px 6px;
        scrollbar-width: thin;
    }

    .ring-option {
        width: 120px;
        min-width: 120px;
        border: 1px solid #d9d9df;
        border-radius: 10px;
        background: #f9f9fc;
        color: #242428;
        padding: 8px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        transition: border-color .15s, box-shadow .15s, background .15s;
    }

    .ring-option:hover {
        border-color: #9bbcf6;
        background: #f4f8ff;
    }

    .ring-option.selected {
        border-color: #2b7fff;
        background: #edf4ff;
        box-shadow: 0 0 0 2px rgba(43, 127, 255, 0.16);
    }

    .ring-preview {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #ffffff;
        border: 1px solid #e0e0e6;
        overflow: hidden;
    }

    .ring-preview img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .ring-fallback {
        font-size: 18px;
        font-weight: 700;
        color: #4d4d57;
    }

    .ring-name {
        width: 100%;
        font-size: 12px;
        line-height: 1.2;
        text-align: center;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .ring-kind {
        font-size: 11px;
        color: #6f6f76;
    }

    .saved {
        color: #1f9d55;
        font-size: 13px;
        font-weight: 600;
    }

    .mcp-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 18px;
    }

    .mcp-row {
        display: flex;
        align-items: center;
        gap: 10px;
        border: 1px solid #e4e4e8;
        border-radius: 8px;
        padding: 8px 12px;
        background: #fafafa;
    }

    .mcp-info {
        display: flex;
        flex-direction: column;
        flex: 1;
        min-width: 0;
    }

    .mcp-name {
        font-size: 13px;
        font-weight: 600;
        color: #1c1c1e;
    }

    .mcp-name .ti {
        font-size: 14px;
        color: #6b6b70;
        margin-right: 2px;
    }

    .mcp-meta {
        font-size: 12px;
        color: #8a8a90;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .mcp-remove {
        background: #fdeced;
        color: #b3261e;
        border: 1px solid #f3c6c4;
        border-radius: 8px;
        padding: 6px 12px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .mcp-remove:hover {
        background: #fbdedf;
    }

    .mcp-add {
        border-top: 1px solid #ececf0;
        padding-top: 16px;
    }

    .mcp-add h3 {
        font-size: 14px;
        font-weight: 600;
        margin: 0 0 12px;
    }

    .mcp-add textarea {
        min-height: 0;
        font-family: Consolas, 'Courier New', monospace;
        font-size: 13px;
    }

    .mcp-error {
        color: #b3261e;
        font-size: 12px;
        margin: 0 0 10px;
    }

    @@media (max-width: 780px) {
        .settings {
            padding: 20px 16px 30px;
        }

        .settings-panel {
            grid-template-columns: 1fr;
        }

        .tabs {
            flex-direction: row;
        }

        .tab {
            flex: 1;
            text-align: center;
        }

