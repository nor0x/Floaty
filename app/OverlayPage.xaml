<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Floaty"
    xmlns:icons="clr-namespace:Floaty.IconFont"
    x:Class="Floaty.OverlayPage"
    x:DataType="local:OverlayPage"
    BackgroundColor="Transparent">

    <!-- Whole-window layout: chat panel (hidden until opened) beside the ring, which sits in the
         center column. The panel opens into the left or right side column depending on available
         screen space (see OverlayPage.ApplyChatSide); the unused side column is collapsed to 0 so
         the ring stays flush against the window edge that the resize anchors. Everything outside the
         drawn pixels is transparent so the desktop shows through. -->
    <Grid RowDefinitions="Auto"
        BackgroundColor="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LeftSpace" Width="0" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition x:Name="RightSpace" Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Slide-out chat panel: scrollable message list above, input box at the bottom.
             Collapsed by default; toggled by tapping the ring. Grid.Column and Margin are set at
             runtime to place it on the correct side of the ring. -->
        <Border x:Name="ChatPanel"
            Grid.Column="2"
            IsVisible="False"
            VerticalOptions="Start"
            Margin="-30,10,0,0"
            Stroke="#22FFFFFF"
            StrokeThickness="1"
            BackgroundColor="#E61C1C1E"
            Padding="14,8,8,8"
            StrokeShape="RoundRectangle 10"
            SizeChanged="OnChatPanelSizeChanged">
            <!-- Content + a right-edge resize grip overlaid on top of it. -->
            <Grid>
                <!-- Messages area sizes to content (collapsed when empty) up to MessagesList's
                 MaximumHeightRequest; beyond that the CollectionView scrolls. Input row is always shown. -->
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="0">

                    <CollectionView x:Name="MessagesList"
                        Grid.Row="0"
                        VerticalScrollBarVisibility="Never"
                        IsVisible="False"
                        MaximumHeightRequest="240"
                        ItemTemplate="{StaticResource ChatListSelector}" />
                    <Border x:Name="SlashSuggestionsPanel"
                        Grid.Row="1"
                        Margin="-5,0,15,0"
                        IsVisible="False"
                        MaximumHeightRequest="132"
                        BackgroundColor="#CC151517"
                        Stroke="#33FFFFFF"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 10"
                        Padding="6,4">
                        <CollectionView x:Name="SlashSuggestionsList"
                            SelectionMode="Single"
                            SelectionChanged="OnSlashSuggestionsSelectionChanged"
                            VerticalScrollBarVisibility="Never"
                            ItemsLayout="VerticalList">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="{x:Null}">
                                    <Grid Padding="6,4" ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
                                        <Label Grid.Column="0"
                                            Text="{Binding Icon}"
                                            FontFamily="TablerIconsLine"
                                            TextColor="#9FC5FF"
                                            FontSize="15"
                                            VerticalOptions="Center"
                                            WidthRequest="18"
                                            HorizontalTextAlignment="Center" />
                                        <Label Grid.Column="1"
                                            Text="{Binding Token}"
                                            TextColor="White"
                                            FontSize="13"
                                            FontAttributes="Bold"
                                            VerticalOptions="Center" />
                                        <Label Grid.Column="2"
                                            Text="{Binding Description}"
                                            TextColor="#CCFFFFFF"
                                            FontSize="12"
                                            VerticalOptions="Center"
                                            LineBreakMode="TailTruncation" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>
                    <Grid Grid.Row="2"
                        ColumnDefinitions="Auto,*,Auto"
                        HorizontalOptions="Fill"
                        Margin="-6,0,-6,0">
                        <!-- Chevron: collapse the chat panel entirely. Column + glyph are set at
                             runtime so it points toward the ring on whichever side the panel opened. -->
                        <Button x:Name="CollapseButton"
                            Text="{x:Static icons:TablerLine.CaretLeft}"
                            FontFamily="TablerIconsLine"
                            Clicked="OnCollapseChatClicked"
                            Grid.Column="0"
                            SemanticProperties.Description="Collapse chat"
                            WidthRequest="16"
                            Padding="0"
                            FontSize="14"
                            HorizontalOptions="Start"
                            VerticalOptions="Fill"
                            BackgroundColor="#55FFFFFF"
                            TextColor="White" />
                        <Border
                            Grid.Column="1"
                            BackgroundColor="#22FFFFFF"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 6">
                            <Grid ColumnDefinitions="*,Auto">
                                <Entry x:Name="ChatEntry"
                                    Grid.Column="0"
                                    Placeholder="Ask Floaty…"
                                    PlaceholderColor="#99FFFFFF"
                                    TextColor="White"
                                    BackgroundColor="Transparent"
                                    ReturnType="Send"
                                    TextChanged="OnChatEntryTextChanged"
                                    Completed="OnSendClicked" />
                                <Button Grid.Column="1"
                                    Text="{x:Static icons:TablerLine.Send}"
                                    FontFamily="TablerIconsLine"
                                    Clicked="OnSendClicked"
                                    SemanticProperties.Description="Send message"
                                    WidthRequest="36"
                                    HeightRequest="36"
                                    Padding="0"
                                    CornerRadius="0"
                                    FontSize="16"
                                    BackgroundColor="#3A6DF0"
                                    TextColor="White" />
                            </Grid>
                        </Border>
                        <!-- Resize grip: drag to change the chat panel width. The transparent strip
                        is the hit area; the thin bar is the visible affordance. Sits on the panel's
                        outer edge — its column is set at runtime to match the panel's side. -->
                        <Border x:Name="ResizeGrip"
                            WidthRequest="12"
                            Margin="0,0,0,0"
                            Grid.Column="2"
								VerticalOptions="Fill"
                            BackgroundColor="Transparent"
                            Stroke="Transparent">
                            <Border WidthRequest="4"
                                HeightRequest="34"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                BackgroundColor="#55FFFFFF"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 2" />
                            <Border.GestureRecognizers>
                                <PanGestureRecognizer PanUpdated="OnResizeHandlePanUpdated" />
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>

                </Grid>
            </Grid>
        </Border>

        <!-- Ring + transient capture toast, stacked so the toast sits just below the ring. The ring
             lives in the center column; the chat panel opens into the left or right side column. -->
        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="End">

            <!-- Draggable swim ring. Pan moves the window and rolls the ring. -->
            <Image x:Name="Ring"
                Source="ring1.png"
                Aspect="AspectFit"
                HeightRequest="148"
                WidthRequest="148"
                HorizontalOptions="Fill"
                VerticalOptions="Fill">
                <FlyoutBase.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Float to taskbar"
                            Clicked="OnFloatToTaskbarClicked">
                            <MenuFlyoutItem.IconImageSource>
                                <FontImageSource FontFamily="TablerIconsLine"
                                    Glyph="{x:Static icons:TablerLine.LayoutBottombar}"
                                    Color="{AppThemeBinding Light=#1C1C1E, Dark=White}" />
                            </MenuFlyoutItem.IconImageSource>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Settings"
                            Clicked="OnSettingsClicked">
                            <MenuFlyoutItem.IconImageSource>
                                <FontImageSource FontFamily="TablerIconsLine"
                                    Glyph="{x:Static icons:TablerLine.Settings}"
                                    Color="{AppThemeBinding Light=#1C1C1E, Dark=White}" />
                            </MenuFlyoutItem.IconImageSource>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Close Floaty"
                            Clicked="OnCloseClicked">
                            <MenuFlyoutItem.IconImageSource>
                                <FontImageSource FontFamily="TablerIconsLine"
                                    Glyph="{x:Static icons:TablerLine.CircleX}"
                                    Color="{AppThemeBinding Light=#1C1C1E, Dark=White}" />
                            </MenuFlyoutItem.IconImageSource>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </FlyoutBase.ContextFlyout>
                <Image.GestureRecognizers>
                    <PanGestureRecognizer PanUpdated="OnRingPanUpdated" />
                    <TapGestureRecognizer Tapped="OnRingTapped" />
                </Image.GestureRecognizers>
            </Image>
            <Label x:Name="CaptureToast"
                IsVisible="False"
                Opacity="0"
                Text=""
                FontSize="11"
                TextColor="White"
                HorizontalTextAlignment="Center"
                LineBreakMode="TailTruncation"
                MaximumWidthRequest="148"
                Padding="8,3"
                BackgroundColor="#CC202020" />
        </VerticalStackLayout>

    </Grid>

    <ContentPage.Resources>
        <Style x:Key="OverlayButton" TargetType="Button">
            <Setter Property="WidthRequest" Value="36" />
            <Setter Property="HeightRequest" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="BackgroundColor" Value="#CC202020" />
            <Setter Property="TextColor" Value="White" />
        </Style>

        <!-- Chat message bubble (also used by the message list). -->
        <DataTemplate x:Key="MessageTemplate" x:DataType="local:ChatMessageVm">
            <Grid Padding="0,3">
                <Border HorizontalOptions="{Binding Alignment}"
                    MaximumWidthRequest="420"
                    BackgroundColor="{Binding BubbleColor}"
                    Stroke="Transparent"
                    Padding="10,7"
                    StrokeShape="RoundRectangle 12">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding Text}"
                            TextColor="White"
                            FontSize="13"
                            LineBreakMode="WordWrap" />

                        <!-- Memory sources cited for this answer (RAG provenance). -->
                        <VerticalStackLayout IsVisible="{Binding HasCitations}" Spacing="3">
                            <Label Text="Sources"
                                TextColor="#99FFFFFF"
                                FontSize="10"
                                FontAttributes="Bold" />
                            <VerticalStackLayout Spacing="3"
                                BindableLayout.ItemsSource="{Binding Citations}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="local:CitationVm">
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="{Binding Title}"
                                                TextColor="#DDFFFFFF"
                                                FontSize="11"
                                                VerticalOptions="Center"
                                                LineBreakMode="TailTruncation"
                                                MaximumWidthRequest="150" />
                                            <Border IsVisible="{Binding HasImage}"
                                                BackgroundColor="#55FFFFFF"
                                                Stroke="Transparent"
                                                Padding="6,1"
                                                StrokeShape="RoundRectangle 7">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding OpenImageCommand}" />
                                                </Border.GestureRecognizers>
                                                <Label TextColor="White" FontSize="11">
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span Text="{x:Static icons:TablerLine.Photo}"
                                                                FontFamily="TablerIconsLine" />
                                                            <Span Text=" image" />
                                                        </FormattedString>
                                                    </Label.FormattedText>
                                                </Label>
                                            </Border>
                                            <Border IsVisible="{Binding HasText}"
                                                BackgroundColor="#55FFFFFF"
                                                Stroke="Transparent"
                                                Padding="6,1"
                                                StrokeShape="RoundRectangle 7">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding OpenTextCommand}" />
                                                </Border.GestureRecognizers>
                                                <Label TextColor="White" FontSize="11">
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span Text="{x:Static icons:TablerLine.FileText}"
                                                                FontFamily="TablerIconsLine" />
                                                            <Span Text=" text" />
                                                        </FormattedString>
                                                    </Label.FormattedText>
                                                </Label>
                                            </Border>
                                        </HorizontalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Conversation switcher row (shown in the message list under /chats). -->
        <DataTemplate x:Key="ConversationTemplate" x:DataType="local:ConversationItemVm">
            <Grid Padding="0,3" ColumnDefinitions="*,Auto" ColumnSpacing="6">
                <Border Grid.Column="0"
                    BackgroundColor="#2EFFFFFF"
                    Stroke="Transparent"
                    Padding="10,7"
                    StrokeShape="RoundRectangle 10">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenCommand}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="1">
                        <Label Text="{Binding Title}"
                            TextColor="White"
                            FontSize="13"
                            LineBreakMode="TailTruncation" />
                        <Label Text="{Binding Subtitle}"
                            TextColor="#99FFFFFF"
                            FontSize="11"
                            LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>
                </Border>
                <Button Grid.Column="1"
                    IsVisible="{Binding HasDelete}"
                    Command="{Binding DeleteCommand}"
                    Text="✕"
                    WidthRequest="30"
                    HeightRequest="30"
                    Padding="0"
                    CornerRadius="15"
                    FontSize="12"
                    VerticalOptions="Center"
                    BackgroundColor="#33FFFFFF"
                    TextColor="White" />
            </Grid>
        </DataTemplate>

        <local:ChatListTemplateSelector x:Key="ChatListSelector"
            MessageTemplate="{StaticResource MessageTemplate}"
            ConversationTemplate="{StaticResource ConversationTemplate}" />
    </ContentPage.Resources>

</ContentPage>