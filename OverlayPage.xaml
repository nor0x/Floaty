<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Floaty"
    x:Class="Floaty.OverlayPage"
    x:DataType="local:OverlayPage"
    BackgroundColor="Transparent">

    <!-- Whole-window layout: chat panel (hidden until opened) on top, the ring and a minimal
         action bar anchored at the bottom. Everything outside the drawn pixels is transparent so
         the desktop shows through. The window grows upward when the chat panel slides out. -->
    <Grid RowDefinitions="Auto"
        ColumnDefinitions="Auto,*"
        BackgroundColor="Transparent">

        <!-- Slide-out chat panel: scrollable message list above, input box at the bottom.
             Collapsed by default; toggled by the 💬 button. -->
        <Border x:Name="ChatPanel"
            Grid.Column="1"
            IsVisible="False"
            VerticalOptions="Start"
            Margin="-30,10,0,0"
            Stroke="#22FFFFFF"
            StrokeThickness="1"
            BackgroundColor="#E61C1C1E"
            Padding="14,8,8,8"
            StrokeShape="RoundRectangle 10"
            SizeChanged="OnChatPanelSizeChanged">
            <!-- Content + a right-edge resize grip overlaid on top of it. -->
            <Grid>
                <!-- Messages area sizes to content (collapsed when empty) up to MessagesList's
                 MaximumHeightRequest; beyond that the CollectionView scrolls. Input row is always shown. -->
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="0">

                    <CollectionView x:Name="MessagesList"
                        Grid.Row="0"
                        VerticalScrollBarVisibility="Never"
                        IsVisible="False"
                        MaximumHeightRequest="240">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="local:ChatMessageVm">
                                <Grid Padding="0,3">
                                    <Border HorizontalOptions="{Binding Alignment}"
                                        MaximumWidthRequest="420"
                                        BackgroundColor="{Binding BubbleColor}"
                                        Stroke="Transparent"
                                        Padding="10,7"
                                        StrokeShape="RoundRectangle 12">
                                        <Label Text="{Binding Text}"
                                            TextColor="White"
                                            FontSize="13"
                                            LineBreakMode="WordWrap" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Border x:Name="SlashSuggestionsPanel"
                        Grid.Row="1"
                        Margin="-5,0,15,0"
                        IsVisible="False"
                        MaximumHeightRequest="132"
                        BackgroundColor="#CC151517"
                        Stroke="#33FFFFFF"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 10"
                        Padding="6,4">
                        <CollectionView x:Name="SlashSuggestionsList"
                            SelectionMode="Single"
                            SelectionChanged="OnSlashSuggestionsSelectionChanged"
                            VerticalScrollBarVisibility="Never"
                            ItemsLayout="VerticalList">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="{x:Null}">
                                    <Grid Padding="6,4" ColumnDefinitions="Auto,*">
                                        <Label Grid.Column="0"
                                            Text="{Binding Token}"
                                            TextColor="White"
                                            FontSize="13"
                                            FontAttributes="Bold"
                                            Margin="0,0,8,0" />
                                        <Label Grid.Column="1"
                                            Text="{Binding Description}"
                                            TextColor="#CCFFFFFF"
                                            FontSize="12"
                                            LineBreakMode="TailTruncation" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>
                    <Border Grid.Row="2"
                        Margin="-5,0,15,0"
                        BackgroundColor="#22FFFFFF"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 6">
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry x:Name="ChatEntry"
                                Grid.Column="0"
                                Placeholder="Ask Floaty…"
                                PlaceholderColor="#99FFFFFF"
                                TextColor="White"
                                BackgroundColor="Transparent"
                                ReturnType="Send"
                                TextChanged="OnChatEntryTextChanged"
                                Completed="OnSendClicked" />
                            <Button Grid.Column="1"
                                Text="➤"
                                Clicked="OnSendClicked"
                                SemanticProperties.Description="Send message"
                                WidthRequest="36"
                                HeightRequest="36"
                                Padding="0"
                                CornerRadius="0"
                                FontSize="15"
                                BackgroundColor="#3A6DF0"
                                TextColor="White" />
                        </Grid>
                    </Border>

                </Grid>

                <!-- Right-edge controls: a chevron to fully collapse the panel and, below it, a
                grip
                     to drag the panel width. -->
                <HorizontalStackLayout HorizontalOptions="End"
                    VerticalOptions="End"
                    Spacing="0"
                    Margin="0,0,-10,0">

                    <!-- Chevron: collapse the chat panel entirely. -->
                    <Button Text="["
                        Clicked="OnCollapseChatClicked"
                        SemanticProperties.Description="Collapse chat"
                        WidthRequest="10"
                        HeightRequest="34"
                        Padding="0"
                        FontSize="14"
                        BackgroundColor="#55FFFFFF"
                        TextColor="White" />
                    <!-- Resize grip: drag to change the chat panel width. The transparent strip is
                    the
                         hit area; the thin bar is the visible affordance. -->
                    <Border WidthRequest="7"
                        Margin="0,0,4,0"
                        HeightRequest="40"
                        BackgroundColor="Transparent"
                        Stroke="Transparent">
                        <Border WidthRequest="4"
                            HeightRequest="34"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            BackgroundColor="#55FFFFFF"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 2" />
                        <Border.GestureRecognizers>
                            <PanGestureRecognizer PanUpdated="OnResizeHandlePanUpdated" />
                        </Border.GestureRecognizers>
                    </Border>

                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- Action bar + transient capture toast, stacked so the toast sits just above the buttons. -->
        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="End">

            <!-- Draggable swim ring. Pan moves the window and rolls the ring. -->
			<Image x:Name="Ring"
                Source="ring1.png"
                Aspect="AspectFit"
                HeightRequest="148"
                WidthRequest="148"
                HorizontalOptions="Fill"
                VerticalOptions="Fill">
				<FlyoutBase.ContextFlyout>
					<MenuFlyout>
						<MenuFlyoutItem Text="Float to taskbar"
                            Clicked="OnFloatToTaskbarClicked" />
						<MenuFlyoutSeparator />
						<MenuFlyoutItem Text="Settings"
                            Clicked="OnSettingsClicked" />
						<MenuFlyoutSeparator />
						<MenuFlyoutItem Text="Close Floaty"
                            Clicked="OnCloseClicked" />
					</MenuFlyout>
				</FlyoutBase.ContextFlyout>
				<Image.GestureRecognizers>
					<PanGestureRecognizer PanUpdated="OnRingPanUpdated" />
					<TapGestureRecognizer Tapped="OnRingTapped" />
				</Image.GestureRecognizers>
			</Image>
			<Label x:Name="CaptureToast"
                IsVisible="False"
                Opacity="0"
                Text=""
                FontSize="11"
                TextColor="White"
                HorizontalTextAlignment="Center"
                LineBreakMode="TailTruncation"
                MaximumWidthRequest="180"
                Padding="8,3"
                BackgroundColor="#CC202020" />
		</VerticalStackLayout>

    </Grid>

    <ContentPage.Resources>
        <Style x:Key="OverlayButton" TargetType="Button">
            <Setter Property="WidthRequest" Value="36" />
            <Setter Property="HeightRequest" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="BackgroundColor" Value="#CC202020" />
            <Setter Property="TextColor" Value="White" />
        </Style>
    </ContentPage.Resources>

</ContentPage>